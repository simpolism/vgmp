<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vgmp_background"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/vgmp_surface"
        android:navigationIcon="@drawable/ic_skip_previous"
        app:navigationIconTint="@color/vgmp_text_primary"
        app:title="Settings"
        app:titleTextColor="@color/vgmp_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView style="@style/VGMP.SettingsHeader" android:text="UI" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_open_player_on_selection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:text="Open Player when selecting a track"
                android:textColor="@color/vgmp_text_primary" />

            <TextView style="@style/VGMP.SettingsHeader" android:text="Filesystem" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_zip_browsing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:text="Browse ZIP archives as folders"
                android:textColor="@color/vgmp_text_primary" />

            <TextView style="@style/VGMP.SettingsHeader" android:text="Playback" />
            <TextView style="@style/VGMP.SettingsLabel" android:text="Embedded loop repeats" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <SeekBar
                    android:id="@+id/seekbar_loop_repeats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="10"
                    android:progressTint="@color/vgmp_accent"
                    android:thumbTint="@color/vgmp_accent" />
                <TextView
                    android:id="@+id/tv_loop_repeats"
                    android:layout_width="92dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/vgmp_text_secondary" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Additional repeats of an embedded loop section when the format provides one."
                android:textColor="@color/vgmp_text_secondary"
                android:textSize="12sp" />

            <TextView style="@style/VGMP.SettingsHeader" android:text="Visualization" />
            <TextView style="@style/VGMP.SettingsLabel" android:text="Fullscreen style" />
            <RadioGroup
                android:id="@+id/radio_analyzer_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/radio_kaleidoscope"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kaleidoscope"
                    android:textColor="@color/vgmp_text_primary" />
                <RadioButton
                    android:id="@+id/radio_bars"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Prism Bars"
                    android:textColor="@color/vgmp_text_primary" />
            </RadioGroup>

            <TextView style="@style/VGMP.SettingsLabel" android:text="Frequency axis" />
            <RadioGroup
                android:id="@+id/radio_visualizer_axis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/radio_axis_linear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Linear"
                    android:textColor="@color/vgmp_text_primary" />
                <RadioButton
                    android:id="@+id/radio_axis_log"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Logarithmic"
                    android:textColor="@color/vgmp_text_primary" />
            </RadioGroup>

            <TextView style="@style/VGMP.SettingsLabel" android:text="Amplitude response" />
            <RadioGroup
                android:id="@+id/radio_visualizer_response"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/radio_response_raw"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Raw"
                    android:textColor="@color/vgmp_text_primary" />
                <RadioButton
                    android:id="@+id/radio_response_balanced"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Balanced"
                    android:textColor="@color/vgmp_text_primary" />
            </RadioGroup>

            <TextView style="@style/VGMP.SettingsLabel" android:text="Refresh rate" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <SeekBar
                    android:id="@+id/seekbar_visualizer_fps"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="225"
                    android:progressTint="@color/vgmp_accent"
                    android:thumbTint="@color/vgmp_accent" />
                <TextView
                    android:id="@+id/tv_visualizer_fps"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/vgmp_text_secondary" />
            </LinearLayout>

            <TextView style="@style/VGMP.SettingsHeader" android:text="Chip / backend" />
            <TextView style="@style/VGMP.SettingsLabel" android:text="VGM playback timing" />
            <RadioGroup
                android:id="@+id/radio_vgm_timing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/radio_timing_auto"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto"
                    android:textColor="@color/vgmp_text_primary" />
                <RadioButton
                    android:id="@+id/radio_timing_60"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="60 Hz"
                    android:textColor="@color/vgmp_text_primary" />
                <RadioButton
                    android:id="@+id/radio_timing_50"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="50 Hz"
                    android:textColor="@color/vgmp_text_primary" />
            </RadioGroup>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Global override for VGM/VGZ timing; Auto honors the file header."
                android:textColor="@color/vgmp_text_secondary"
                android:textSize="12sp" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_bass_enabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:text="Bass boost"
                android:textColor="@color/vgmp_text_primary" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_reverb_enabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp"
                android:text="Reverb"
                android:textColor="@color/vgmp_text_primary" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:textColor="@color/vgmp_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
